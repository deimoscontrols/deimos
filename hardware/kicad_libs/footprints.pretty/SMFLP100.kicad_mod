(module "SMFLP100" (layer F.Cu)
  (descr "SMFLP10.0-2")
  (tags "LED")
  (fp_text reference LED** (at 0.000 0) (layer F.SilkS)
    (effects (font (size 1.27 1.27) (thickness 0.254)))
  )
  (fp_text user %R (at 0.000 0) (layer F.Fab)
    (effects (font (size 1.27 1.27) (thickness 0.254)))
  )
  (fp_text value "SMFLP100" (at 0.000 0) (layer F.SilkS) hide
    (effects (font (size 1.27 1.27) (thickness 0.254)))
  )
  (fp_line (start -4.5 -6.5) (end 4.5 -6.5) (layer F.CrtYd) (width 0.1))
  (fp_line (start 4.5 -6.5) (end 4.5 6.5) (layer F.CrtYd) (width 0.1))
  (fp_line (start 4.5 6.5) (end -4.5 6.5) (layer F.CrtYd) (width 0.1))
  (fp_line (start -4.5 6.5) (end -4.5 -6.5) (layer F.CrtYd) (width 0.1))
  (fp_line (start -3.5 -2) (end -3.5 2) (layer F.Fab) (width 0.1))
  (fp_line (start -3.5 2) (end -3.5 2) (layer F.Fab) (width 0.1))
  (fp_line (start 3.5 2) (end 3.5 -2) (layer F.Fab) (width 0.1))
  (fp_line (start 3.5 -2) (end 3.5 -2) (layer F.Fab) (width 0.1))
  (fp_line (start -3.5 -2) (end -3.5 2) (layer F.SilkS) (width 0.2))
  (fp_line (start -3.5 2) (end -3.5 2) (layer F.SilkS) (width 0.2))
  (fp_line (start 3.5 2) (end 3.5 -2) (layer F.SilkS) (width 0.2))
  (fp_line (start 3.5 -2) (end 3.5 -2) (layer F.SilkS) (width 0.2))
  (fp_line (start -4.1 -0) (end -4.1 -0) (layer F.SilkS) (width 0.1))
  (fp_line (start -4.2 -0) (end -4.2 -0) (layer F.SilkS) (width 0.1))
  (fp_arc (start 0 2) (end -3.500 2) (angle -180) (layer F.Fab) (width 0.1))
  (fp_arc (start 0 -2) (end 3.500 -2) (angle -180) (layer F.Fab) (width 0.1))
  (fp_arc (start 0 2) (end -3.500 2) (angle -180) (layer F.SilkS) (width 0.2))
  (fp_arc (start 0 -2) (end 3.500 -2) (angle -180) (layer F.SilkS) (width 0.2))
  (fp_arc (start -4.15 -0) (end -4.100 -0) (angle -180) (layer F.SilkS) (width 0.1))
  (fp_arc (start -4.15 -0) (end -4.200 -0) (angle -180) (layer F.SilkS) (width 0.1))
  (pad 1 smd rect (at 0.000 -0 90) (size 3.800 3.800) (layers F.Cu F.Paste F.Mask))
  (pad MH1 np_thru_hole circle (at 0.000 3.7) (size 2.5654 2.5654) (drill 2.5654) (layers *.Cu *.Mask))
  (pad MH2 np_thru_hole circle (at 0.000 -3.7) (size 2.5654 2.5654) (drill 2.5654) (layers *.Cu *.Mask))
  (model SMFLP10.0.stp
    (at (xyz 0 0 0))
    (scale (xyz 1 1 1))
    (rotate (xyz 0 0 0))
  )
)

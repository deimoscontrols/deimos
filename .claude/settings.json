{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",

  "alwaysThinkingEnabled": true,

  "permissions": {
    "allow": [
      "Bash(git add:*)",
      "Bash(git branch:*)",
      "Bash(git check-ignore:*)",
      "Bash(git checkout:*)",
      "Bash(git cherry-pick:*)",
      "Bash(git cherry:*)",
      "Bash(git commit:*)",
      "Bash(git config:*)",
      "Bash(git diff:*)",
      "Bash(git fetch:*)",
      "Bash(git fsck:*)",
      "Bash(git log:*)",
      "Bash(git ls-tree:*)",
      "Bash(git merge-base:*)",
      "Bash(git merge:*)",
      "Bash(git pull:*)",
      "Bash(git rebase:*)",
      "Bash(git reflog:*)",
      "Bash(git reset:*)",
      "Bash(git rev-list:*)",
      "Bash(git rev-parse:*)",
      "Bash(git show-ref:*)",
      "Bash(git show:*)",
      "Bash(git stack:*)",
      "Bash(git status:*)",
      "Bash(git symbolic-ref:*)",
      "Bash(git update-ref:*)",

      "Bash(gh api graphql:*)",
      "Bash(gh api repos:*)",
      "Bash(gh api user:*)",
      "Bash(gh auth status)",
      "Bash(gh issue:*)",
      "Bash(gh pr checks:*)",
      "Bash(gh pr checkout:*)",
      "Bash(gh pr comment:*)",
      "Bash(gh pr diff:*)",
      "Bash(gh pr list:*)",
      "Bash(gh pr review:*)",
      "Bash(gh pr view:*)",
      "Bash(gh repo view:*)",
      "Bash(gh run list:*)",
      "Bash(gh run view:*)",
      "Bash(gh run watch:*)",

      "Bash(pnpm exec eslint *)",
      "Bash(pnpm exec markdownlint *)",
      "Bash(pnpm exec prettier *)",
      "Bash(pnpm exec tsx *)",
      "Bash(pnpm install:*)",
      "Bash(pnpm openspec *)",
      "Bash(pnpm run check)",
      "Bash(pnpm run validate:*)",
      "Bash(pnpm run validate:shellcheck:*)",
      "Bash(pnpm run validate:structure:*)",

      "Bash(make *)",
      "Bash(make)",

      "Bash(curl:*)",
      "Bash(cut:*)",
      "Bash(date:*)",
      "Bash(diff:*)",
      "Bash(du:*)",
      "Bash(jq:*)",
      "Bash(ls:*)",
      "Bash(mkdir:*)",
      "Bash(mv:*)",
      "Bash(open:*)",
      "Bash(pbcopy)",
      "Bash(pbpaste)",
      "Bash(pwd)",
      "Bash(shellcheck:*)",
      "Bash(sort:*)",
      "Bash(test:*)",
      "Bash(tr:*)",
      "Bash(tree:*)",
      "Bash(wc:*)",
      "Bash(which:*)",

      "Read(/private/tmp/**)",

      "WebFetch(domain:code.claude.com)",
      "WebFetch(domain:developer.mozilla.org)",
      "WebFetch(domain:devdocs.io)",
      "WebFetch(domain:docs.claude.com)",
      "WebFetch(domain:docs.hatchet.run)",
      "WebFetch(domain:eslint.org)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:modelcontextprotocol.io)",
      "WebFetch(domain:nodejs.org)",
      "WebFetch(domain:platform.claude.com)",
      "WebFetch(domain:prettier.io)",
      "WebFetch(domain:raw.githubusercontent.com)",
      "WebFetch(domain:stackoverflow.com)",
      "WebFetch(domain:typescriptlang.org)",
      "WebFetch(domain:www.anthropic.com)",
      "WebFetch(domain:www.npmjs.com)",
      "WebFetch(domain:www.schemastore.org)",

      "WebSearch"
    ]
  },

  "enableAllProjectMcpServers": false,

  "includeCoAuthoredBy": true
}
